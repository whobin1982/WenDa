# 根级环境样例（复制为 .env 并按需修改）
# 警告：任何 .env / .env.local 均不得提交。

# ===== 后端 =====
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# PostgreSQL（开发 / 本地）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=wenda
DB_USER=wenda
DB_PASSWORD=change_me
DB_SCHEMA=public

# Flyway
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# JWT（开发密钥；生产必须使用 32 字节以上随机密钥与 KMS 管理）
JWT_SECRET=change_me_to_a_32_byte_random_string_at_least
JWT_ISSUER=wenda.local
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=1209600

# 审计 / 幂等
AUDIT_ENABLED=true
IDEMPOTENCY_ENABLED=true

# Adapter 默认实现（生产禁用 Mock）
AI_PROVIDER_DEFAULT=disabled
STORAGE_ADAPTER_DEFAULT=local
SCANNER_ADAPTER_DEFAULT=disabled
RENDERER_ADAPTER_DEFAULT=disabled
EMAIL_ADAPTER_DEFAULT=disabled

# 生产 Mock 禁用的硬门禁
PROD_MOCK_DISABLED=true

# OpenAPI
SPRINGDOC_SWAGGER_ENABLED=true
SPRINGDOC_SWAGGER_PATH=/api/v1/openapi

# ===== 前端 =====
VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1
VITE_APP_TITLE=AI 原生本科专业建设与学生能力成长平台
